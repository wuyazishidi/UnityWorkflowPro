# ===== Unity 生成目录 =====
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta data 必须随资源提交（Unity 要求），故不忽略 *.meta

# ===== 收费插件（本地自用，不入库，避免扩散）=====
/Assets/Plugins/
/Assets/Plugins.meta

# ===== Unity / IDE 生成的工程文件 =====
/*.csproj
*.unityproj
/*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.vs/
.gradle/
ExportedObj/
crashlytics-build.properties

# ===== 构建产物 =====
*.apk
*.aab
*.unitypackage
*.app

# ===== 后端(.NET) 生成物 =====
server/**/bin/
server/**/obj/

# ===== Node / UTO 编排层 =====
**/node_modules/
# UTO 本地端口与测试结果（运行期生成）
Packages/cn.etetet.yiuimcp/UTO/.port
Packages/cn.etetet.yiuimcp/UTO/.port.meta

# ===== 工作流运行期产物 =====
/Logs/EditMode-test-results.txt

# ===== Claude Code 个人设置（团队共享的 settings.json / commands / hooks 仍提交）=====
.claude/settings.local.json
# DoD 脏标记（运行期状态）
.claude/.dod-needed

# ===== Figma 同步：个人 token（含 file_content:read，勿入库）+ 拉取中间产物 =====
.figma-token
/Assets/UI/*/.figma/

# ===== OS =====
.DS_Store
Thumbs.db

# ===== Agent scratch / IDE (added by assistant) =====
/_ui_src/
/.idea/
/Logs/
/Test/
